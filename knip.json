{
  "$schema": "./node_modules/knip/schema.json",
  "ignoreBinaries": [
    "make"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "build/*.ts"
      ],
      "project": [
        "build/**/*.ts"
      ]
    },
    "plugins/aks-desktop": {
      "entry": [
        "src/index.tsx",
        "src/**/*.stories.{ts,tsx}",
        "src/**/*.test.{ts,tsx}",
        "src/**/*.guidepup.test.{ts,tsx}",
        "src/utils/azure/**/*.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ],
      "ignore": [
        "src/**/*.d.ts"
      ],
      "ignoreDependencies": [
        "@azure/arm-resourcegraph",
        "@azure/arm-subscriptions",
        "@azure/identity",
        "@iconify/react",
        "@monaco-editor/react",
        "@mui/material",
        "@mui/utils",
        "@storybook/react",
        "@testing-library/jest-dom",
        "@types/libsodium-wrappers",
        "axe-core",
        "eslint-plugin-no-barrel-files",
        "i18next",
        "react-i18next",
        "react-router-dom"
      ],
      "ignoreBinaries": [
        "prettier"
      ]
    }
  },
  "ignoreDependencies": [
    "tsx"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "lint-staged": true,
  "husky": true,
  "tags": [
    "-lintignore"
  ]
}
