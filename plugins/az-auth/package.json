{
  "name": "az-auth",
  "version": "0.1.0",
  "description": "Azure Authentication Headlamp plugin",
  "scripts": {
    "start": "headlamp-plugin start",
    "build": "headlamp-plugin build",
    "format": "headlamp-plugin format",
    "lint": "headlamp-plugin lint",
    "lint-fix": "headlamp-plugin lint --fix",
    "package": "headlamp-plugin package",
    "tsc": "headlamp-plugin tsc",
    "storybook": "headlamp-plugin storybook",
    "storybook-build": "headlamp-plugin storybook-build",
    "test": "headlamp-plugin test",
    "prettier": "prettier --write .",
    "i18n": "headlamp-plugin i18n",
    "bin:build": "esbuild src-bin/azure-api.ts --bundle --minify --outfile=azure-api.js --platform=node --loader:.node=empty --define:import.meta.url=importMetaUrl --banner:js=\"const importMetaUrl=require('url').pathToFileURL(__filename).href;\""
  },
  "keywords": [
    "headlamp",
    "kubernetes",
    "kubernetes-ui",
    "kubernetes-debugging",
    "plugins"
  ],
  "prettier": "@headlamp-k8s/eslint-config/prettier-config",
  "eslintConfig": {
    "extends": [
      "@headlamp-k8s",
      "prettier",
      "plugin:jsx-a11y/recommended"
    ]
  },
  "overrides": {
    "typescript": "5.6.2",
    "react": "^18.3.1",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@kinvolk/headlamp-plugin": "^0.13.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.52.4",
    "@rollup/rollup-darwin-x64": "^4.52.4",
    "@rollup/rollup-linux-arm64": "^4.50.1",
    "@rollup/rollup-linux-arm64-musl": "^4.52.4",
    "@rollup/rollup-linux-x64": "^4.50.1",
    "@rollup/rollup-linux-x64-musl": "^4.52.3",
    "@rollup/rollup-win32-arm64": "^4.50.1",
    "@rollup/rollup-win32-x64": "^4.50.1",
    "husky": "^9.0.0"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/identity-cache-persistence": "^1.3.0"
  },
  "headlamp": {
    "extraDist": {
      "azure-api.js": "azure-api.js"
    }
  }
}
